# Stripe — get keys from https://dashboard.stripe.com/apikeys
# Connect your bank account under Settings → Payouts so money goes to your card/bank.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_here

# Team registration fee (AZN)
STRIPE_TEAM_FEE_AZN=20
STRIPE_CURRENCY=azn

# Local dev with Vercel API: leave empty when using `vercel dev` on the same host.
# GitHub Pages only: set to your Vercel API URL, e.g. https://your-app.vercel.app
# VITE_PAYMENT_API_URL=

# GitHub Pages (optional overrides — defaults are set in vite.config.ts and main.tsx)
# VITE_BASE_PATH=/NextGen-Robotics-Competition/
# VITE_USE_HASH_ROUTER=false
