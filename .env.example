# Stripe — get keys from https://dashboard.stripe.com/apikeys
# Connect your bank account under Settings → Payouts so money goes to your card/bank.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_here

# Team registration fee (AZN)
STRIPE_TEAM_FEE_AZN=20
STRIPE_CURRENCY=azn

# Local dev with Vercel API: leave empty when using `vercel dev` on the same host.
# GitHub Pages only: set to your Vercel API URL, e.g. https://your-app.vercel.app
# VITE_API_URL=https://your-app.vercel.app
# VITE_PAYMENT_API_URL=  (alias for VITE_API_URL)

# Email — contact form + mentor/member welcome emails (set in Vercel, NOT in the browser)
# Option A — Gmail (easiest if you use nextgenazer@gmail.com):
# 1. Google Account → Security → 2-Step Verification → App passwords → create one for "Mail"
# 2. Add to Vercel env:
# GMAIL_USER=nextgenazer@gmail.com
# GMAIL_APP_PASSWORD=your-16-char-app-password
# ORG_EMAIL=nextgenazer@gmail.com
#
# Option B — Resend (https://resend.com):
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=NextGen Robotics <onboarding@resend.dev>
#
# Local test: terminal 1 → npm run dev:api   terminal 2 → npm run dev

# GitHub Pages (optional overrides — defaults are set in vite.config.ts and main.tsx)
# VITE_BASE_PATH=/NextGen-Robotics-Competition/
# VITE_USE_HASH_ROUTER=false

# Supabase — required for shared teams & standings across all visitors (production)
# Create a free project at https://supabase.com, then run the SQL below in SQL Editor.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
#
# SQL (enable RLS policies that allow anon read/write for competition data, or use service role server-side):
# create table public.teams (id text primary key, payload jsonb not null);
# create table public.app_state (key text primary key, payload jsonb not null);
# alter table public.teams enable row level security;
# alter table public.app_state enable row level security;
# create policy "teams anon all" on public.teams for all using (true) with check (true);
# create policy "app_state anon all" on public.app_state for all using (true) with check (true);
