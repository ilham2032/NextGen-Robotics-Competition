# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CORS — add your production frontend URL
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# CSRF — required for HTTPS deployments (e.g. https://your-app.onrender.com)
CSRF_TRUSTED_ORIGINS=

# Database — defaults to SQLite locally.
# In production (Render/Railway), set DATABASE_URL to your Postgres connection string,
# e.g. postgres://user:password@host:5432/dbname
# DATABASE_URL=

# Admin "Clear All Data" — set this to a secret string to enable POST /api/reset/.
# Leave empty to disable the reset endpoint entirely. Must match VITE_ADMIN_RESET_TOKEN
# on the frontend.
ADMIN_RESET_TOKEN=

